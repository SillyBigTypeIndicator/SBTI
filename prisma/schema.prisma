// Silly Big Type Indicator — Prisma schema (SQLite dev; swap URL for Postgres in prod)

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
}

// --- NextAuth (Auth.js) ---
model User {
  id            String    @id @default(cuid())
  name          String?
  email         String?   @unique
  emailVerified DateTime?
  image         String?
  /// Anonymous installs: stable key from cookie when no email login
  anonymousKey  String?   @unique

  accounts Account[]
  sessions Session[]

  submissions        Submission[]
  externalProfiles   ExternalPersonalityProfile[]
  comparisonReports  ComparisonReport[]
  shareCards         ShareCard[]
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

// --- SBTI domain ---
model PersonalityTest {
  id          String   @id @default(cuid())
  slug        String   @unique
  title       String
  description String?
  createdAt   DateTime @default(now())

  questions   Question[]
  submissions Submission[]
}

model Question {
  id                String   @id @default(cuid())
  personalityTestId String
  orderIndex        Int
  prompt            String
  /// JSON: [{ "id": "a", "label": "...", "weights": { "e": 1, "s": 0 } }]
  optionsJson       String

  personalityTest PersonalityTest @relation(fields: [personalityTestId], references: [id], onDelete: Cascade)
  answers         Answer[]

  @@index([personalityTestId, orderIndex])
}

model Submission {
  id                String    @id @default(cuid())
  userId            String?
  personalityTestId String
  startedAt         DateTime  @default(now())
  completedAt     DateTime?

  user            User?            @relation(fields: [userId], references: [id], onDelete: SetNull)
  personalityTest PersonalityTest  @relation(fields: [personalityTestId], references: [id], onDelete: Cascade)
  answers         Answer[]
  result          TestResult?

  @@index([userId])
  @@index([personalityTestId])
}

model Answer {
  id           String @id @default(cuid())
  submissionId String
  questionId   String
  /// Selected option id (string)
  value        String

  submission Submission @relation(fields: [submissionId], references: [id], onDelete: Cascade)
  question   Question   @relation(fields: [questionId], references: [id], onDelete: Cascade)

  @@unique([submissionId, questionId])
}

model TestResult {
  id           String   @id @default(cuid())
  submissionId String   @unique
  typeCode     String
  /// Raw axis scores 0-100 JSON
  scoresJson   String
  /// Full serializable result (strengths, chaos, etc.)
  payloadJson  String
  createdAt    DateTime @default(now())

  submission Submission @relation(fields: [submissionId], references: [id], onDelete: Cascade)
}

model ExternalPersonalityProfile {
  id           String   @id @default(cuid())
  userId       String?
  providerId   String
  rawInputJson String
  normalizedJson String
  label        String
  createdAt    DateTime @default(now())

  user User? @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([userId])
  @@index([providerId])
}

model ComparisonReport {
  id          String   @id @default(cuid())
  userId      String?
  /// SBTI type code at time of compare
  sbtiTypeCode String
  externalProfileId String?
  providerId  String
  overlapScore     Float
  contradictionScore Float
  summaryJson String
  createdAt   DateTime @default(now())

  user User? @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([userId])
}

model ShareCard {
  id         String   @id @default(cuid())
  userId     String?
  typeCode   String
  payloadJson String
  createdAt  DateTime @default(now())

  user User? @relation(fields: [userId], references: [id], onDelete: SetNull)
}
